# Afet Komuta Kontrol — ortam değişkenleri (örnek)
# Gerçek anahtarları asla repoya commit etmeyin.
# Statik frontend: üretimde anahtar sunucu tarafı proxy ile korunmalıdır.

# Google Gemini (vaka skorlama ve stratejik rapor)
GEMINI_API_KEY=

# İsteğe bağlı: model adı (varsayılan uygulama içinde tanımlanır)
# GEMINI_MODEL=gemini-1.5-flash

# Gelecek entegrasyonlar (mock → gerçek API)
# AFAD_API_URL=
# AFAD_API_TOKEN=
